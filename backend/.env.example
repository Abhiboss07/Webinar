# ============================================================================
# Backend environment — copy to ".env" and fill in. NEVER commit the real .env.
# ============================================================================

# ---- Server ----
PORT=4000
NODE_ENV=production

# Public URL of the deployed frontend (Hostinger). Comma-separate for multiple.
# Used for the CORS allow-list. In development, localhost origins are auto-allowed.
FRONTEND_URL=https://awishclinic.com

# Public URL of THIS backend (Render). Informational (health/docs).
API_URL=https://your-render-backend.onrender.com

# ---- Razorpay ----
# Key ID is also used by the frontend (public). Secret is BACKEND-ONLY.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ---- Google Sheets (Apps Script Web App URL) ----
# Deployed google-apps-script.gs web app. The backend posts registrations and
# paid-status updates here; the browser never calls it for writes.
GOOGLE_SHEET_ENDPOINT=https://script.google.com/macros/s/XXXX/exec
# Shared secret that must match the Apps Script Script Property SHEET_SHARED_TOKEN.
# Protects the write endpoints so only this backend can write to the sheet.
SHEET_SHARED_TOKEN=change-me-to-a-long-random-string

# ---- Charge (server-owned — the client cannot change the amount) ----
AMOUNT=9900          # in paise (₹99.00)
CURRENCY=INR
WORKSHOP_NAME=Career Growth & Clinical Excellence Workshop
