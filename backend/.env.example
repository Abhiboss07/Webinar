# ============================================================================
# Backend environment TEMPLATE. Copy to ".env" and fill in REAL values.
# This file is committed and MUST contain placeholders only — NO real secrets.
# The real ".env" is gitignored and must never be committed.
# ============================================================================

# ---- Server ----
PORT=4000
NODE_ENV=production

# ---- Database (MongoDB Atlas) — required for the CMS / admin panel ----
# Create a free cluster at https://cloud.mongodb.com, add a database user, allow
# network access (0.0.0.0/0 for Render), and paste the connection string here.
MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/youngness?retryWrites=true&w=majority

# ---- Admin auth (CMS) ----
# JWT_SECRET signs admin sessions — use a long random string (e.g. `openssl rand -hex 32`).
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=12h
# Bootstrap admin — used ONCE by `npm run seed:admin` to create the first login.
ADMIN_EMAIL=admin@youngness.com
ADMIN_PASSWORD=change_this_strong_password
ADMIN_NAME=Youngness Admin

# Public URLs allowed by CORS — the deployed public site (Hostinger) AND the
# admin panel. Comma-separate multiple origins. In development, localhost origins
# (including the Vite admin on :5173) are auto-allowed.
FRONTEND_URL=https://your-frontend-domain.com,https://admin.your-domain.com

# Public URL of THIS backend (Render). Informational (health/docs).
API_URL=https://your-render-backend.onrender.com

# ---- Razorpay ----
# Key ID is also used by the frontend (public). Secret is BACKEND-ONLY — never expose.
RAZORPAY_KEY_ID=your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# ---- Google Sheets (Apps Script Web App URL) ----
# The deployed google-apps-script.gs web-app URL. The "your_deployment_id" part is
# the Apps Script DEPLOYMENT ID (it is NOT the shared token below).
GOOGLE_SHEET_ENDPOINT=https://script.google.com/macros/s/your_deployment_id/exec

# A secret YOU generate (e.g. awish_super_secret_2026_xxxxx). It must be added as an
# Apps Script Script Property named SHEET_SHARED_TOKEN with the SAME value, so only
# this backend can write to the sheet. Do NOT use the deployment ID here.
SHEET_SHARED_TOKEN=your_shared_token_here

# ---- Media storage (Module 2.3) ----
# "cloudinary" (production) or "local" (dev/fallback → files on disk under UPLOAD_DIR,
# served at <API_URL>/uploads/…). Auto-detects cloudinary when CLOUDINARY_CLOUD_NAME is set.
STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=youngness
# Local adapter only:
UPLOAD_DIR=uploads
MEDIA_MAX_BYTES=26214400   # 25 MB

# ---- Charge (server-owned — the client cannot change the amount) ----
AMOUNT=9900          # in paise (₹99.00)
CURRENCY=INR
WORKSHOP_NAME=Career Growth & Clinical Excellence Workshop
