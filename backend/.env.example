# ============================================================================
# Backend environment TEMPLATE. Copy to ".env" and fill in REAL values.
# This file is committed and MUST contain placeholders only — NO real secrets.
# The real ".env" is gitignored and must never be committed.
# ============================================================================

# ---- Server ----
PORT=4000
NODE_ENV=production

# Public URL of the deployed frontend (Hostinger). Comma-separate for multiple.
# Used for the CORS allow-list. In development, localhost origins are auto-allowed.
FRONTEND_URL=https://your-frontend-domain.com

# Public URL of THIS backend (Render). Informational (health/docs).
API_URL=https://your-render-backend.onrender.com

# ---- Razorpay ----
# Key ID is also used by the frontend (public). Secret is BACKEND-ONLY — never expose.
RAZORPAY_KEY_ID=your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# ---- Google Sheets (Apps Script Web App URL) ----
# The deployed google-apps-script.gs web-app URL. The "your_deployment_id" part is
# the Apps Script DEPLOYMENT ID (it is NOT the shared token below).
GOOGLE_SHEET_ENDPOINT=https://script.google.com/macros/s/your_deployment_id/exec

# A secret YOU generate (e.g. awish_super_secret_2026_xxxxx). It must be added as an
# Apps Script Script Property named SHEET_SHARED_TOKEN with the SAME value, so only
# this backend can write to the sheet. Do NOT use the deployment ID here.
SHEET_SHARED_TOKEN=your_shared_token_here

# ---- Charge (server-owned — the client cannot change the amount) ----
AMOUNT=9900          # in paise (₹99.00)
CURRENCY=INR
WORKSHOP_NAME=Career Growth & Clinical Excellence Workshop
