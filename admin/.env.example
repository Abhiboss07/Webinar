# Base URL of the backend API (Render in production). No trailing slash.
# Dev default is http://localhost:4000 if unset.
VITE_API_BASE=http://localhost:4000

# Public site URL (Hostinger in prod, or your local static server in dev).
# Enables the "Preview" button, which opens <site>/?preview=1 to render the draft.
VITE_PUBLIC_SITE_URL=http://localhost:5500
