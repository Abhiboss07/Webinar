# SPA fallback — serve index.html for every route the filesystem does not have,
# so React Router paths (/login, /registrations, ...) survive a browser refresh.
#
# /assets/ is EXCLUDED from the fallback: a request for a hashed chunk that no
# longer exists (stale index.html after a redeploy) must return a real 404.
# Serving index.html there hands HTML to a dynamic import ("Failed to fetch
# dynamically imported module") and lets browsers/CDNs cache that HTML as the
# chunk. A 404 lets the app's chunk-error recovery reload cleanly instead.
RewriteEngine On
RewriteBase /
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/assets/
RewriteRule . /index.html [L]

# Caching: index.html must always revalidate (it names the current chunk
# hashes), while the content-hashed assets are immutable and can cache forever.
<IfModule mod_headers.c>
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(js|css|png|jpg|jpeg|webp|svg|ico|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
