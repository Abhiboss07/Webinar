# ============================================================================
# Youngness Workshop — production .htaccess for Hostinger (Apache, shared)
# Upload the CONTENTS of frontend-production/ into your /workshop/ directory.
# Pure static site: HTML + compiled CSS + ES-module JS. No Node, no rewrites.
# ============================================================================

# Serve index.html for the /workshop/ directory.
DirectoryIndex index.html

# Don't expose a directory listing if index.html is ever missing.
Options -Indexes

# Default charset.
AddDefaultCharset UTF-8

# ---------------------------------------------------------------------------
# CRITICAL — correct MIME types. ES modules FAIL to load if .js is served as
# text/plain ("Expected a JavaScript module script..."). This is the #1 cause
# of a blank page for module-based static sites on shared hosting.
# ---------------------------------------------------------------------------
<IfModule mod_mime.c>
  AddType text/javascript            .js
  AddType text/javascript            .mjs
  AddType text/css                   .css
  AddType image/svg+xml              .svg
  AddType image/x-icon               .ico
  AddType image/webp                 .webp
  AddType application/json           .json
  AddType font/woff2                 .woff2
</IfModule>

# ---------------------------------------------------------------------------
# Compression (gzip).
# ---------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ---------------------------------------------------------------------------
# Caching. IMPORTANT: the JS/CSS/config filenames are NOT content-hashed and DO
# change between deploys (e.g. config/workshop-config.js → api.prod backend URL).
# So app code MUST revalidate every load — otherwise a re-upload won't take effect
# until the browser cache expires. Only media gets a short cache (not immutable).
# ---------------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  # App code + HTML: always revalidate so deploys / config changes apply immediately.
  ExpiresByType text/css               "access plus 0 seconds"
  ExpiresByType text/javascript        "access plus 0 seconds"
  ExpiresByType application/javascript "access plus 0 seconds"
  ExpiresByType text/html              "access plus 0 seconds"
  # Media: cache a day (rename the file for an instant cache-bust if needed).
  ExpiresByType image/jpeg             "access plus 1 day"
  ExpiresByType image/png              "access plus 1 day"
  ExpiresByType image/webp             "access plus 1 day"
  ExpiresByType image/svg+xml          "access plus 1 day"
  ExpiresByType image/x-icon           "access plus 1 week"
  ExpiresByType font/woff2             "access plus 1 week"
</IfModule>

<IfModule mod_headers.c>
  # App code (HTML/JS/CSS/config): never cache stale — always revalidate (304 if unchanged).
  <FilesMatch "\.(html|js|mjs|css)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  # Static media: cacheable but NOT immutable, so a re-upload propagates within a day.
  <FilesMatch "\.(jpg|jpeg|png|webp|svg|ico|woff2)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>

  # --- Safe security headers (do NOT break Razorpay / Google Fonts) ---
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

  # --- OPTIONAL Content-Security-Policy (commented: enable + set <RENDER_URL>) ---
  # A strict CSP can break Razorpay/fonts if mis-set. If you enable it, replace
  # https://YOUR-BACKEND.onrender.com with your real Render URL.
  # Header always set Content-Security-Policy "default-src 'self'; \
  #   script-src 'self' https://checkout.razorpay.com; \
  #   style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; \
  #   font-src 'self' https://fonts.gstatic.com; \
  #   img-src 'self' data: https:; \
  #   connect-src 'self' https://YOUR-BACKEND.onrender.com https://*.razorpay.com https://lumberjack.razorpay.com; \
  #   frame-src https://*.razorpay.com https://api.razorpay.com; \
  #   object-src 'none'; base-uri 'self'"
</IfModule>
